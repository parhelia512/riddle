<idea-plugin>
    <id>org.riddlelang.intellij</id>
    <name>Riddle</name>
    <vendor>Riddle contributors</vendor>
    <description>Riddle language support powered by riddle-lsp.</description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lsp</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="Riddle"
            implementationClass="org.riddlelang.intellij.RiddleFileType"
            fieldName="INSTANCE"
            language="Riddle"
            extensions="rid" />
        <platform.lsp.serverSupportProvider
            implementation="org.riddlelang.intellij.RiddleLspServerSupportProvider" />
    </extensions>
</idea-plugin>
