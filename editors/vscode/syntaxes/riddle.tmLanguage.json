{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Riddle",
  "scopeName": "source.riddle",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#attributes" },
    { "include": "#declarations" },
    { "include": "#bindings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#numbers" },
    { "include": "#calls" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.riddle",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.other.raw.riddle",
          "begin": "\\br(#+)?\"",
          "end": "\"\\1"
        },
        {
          "name": "string.quoted.double.riddle",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.riddle",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.riddle",
          "match": "'([^'\\\\]|\\\\.)'"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.annotation.riddle",
          "match": "#\\[[^\\]]*\\]"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(fun)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.riddle" },
            "2": { "name": "entity.name.function.riddle" }
          }
        },
        {
          "match": "\\b(struct|enum|trait|type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.riddle" },
            "2": { "name": "entity.name.type.riddle" }
          }
        },
        {
          "match": "\\b(mod)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.namespace.riddle" },
            "2": { "name": "entity.name.namespace.riddle" }
          }
        }
      ]
    },
    "bindings": {
      "patterns": [
        {
          "match": "\\b(let)\\s+(?:(mut)\\s+)?([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.riddle" },
            "2": { "name": "storage.modifier.mutable.riddle" },
            "3": { "name": "variable.other.readwrite.riddle" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.riddle",
          "match": "\\b(?:if|else|while|for|match|break|continue|return)\\b"
        },
        {
          "name": "keyword.other.riddle",
          "match": "\\b(?:as|const|crate|extern|impl|mut|pub|self|super|unsafe|use|where)\\b"
        },
        {
          "name": "constant.language.boolean.riddle",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.riddle",
          "match": "\\b(?:i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f16|f32|f64|f128|bool|str|char)\\b"
        },
        {
          "name": "entity.name.type.riddle",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.riddle",
          "match": "\\b(?:[0-9]+(?:\\.[0-9]+)?)(?:i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f16|f32|f64|f128)?\\b"
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "name": "entity.name.function.call.riddle",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.riddle",
          "match": "(?:->|=>|==|!=|<=|>=|&&|\\|\\||<<|>>|[+\\-*/%&|^!<>=])"
        }
      ]
    }
  }
}
