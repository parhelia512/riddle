impl Add for i8 { type Output = i8; fun add(self, rhs: Self) -> Self::Output { self + rhs } }
impl Add for i16 { type Output = i16; fun add(self, rhs: Self) -> Self::Output { self + rhs } }
impl Add for i32 { type Output = i32; fun add(self, rhs: Self) -> Self::Output { self + rhs } }
