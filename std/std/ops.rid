use crate::std::iter::{IntoIterator, Iterator};
use crate::std::option::Option;

pub struct Range {
    start: i32,
    end: i32,
}

impl Range {
    pub fun new(start: i32, end: i32) -> Range {
        Range { start, end }
    }
}

pub fun range(start: i32, end: i32) -> Range {
    Range::new(start, end)
}

impl Iterator for Range {
    type Item = i32;

    fun next(&mut self) -> Option<Self::Item> {
        if self.start < self.end {
            let value = self.start;
            self.start += 1;
            Option::Some(value)
        } else {
            Option::None
        }
    }
}

impl IntoIterator for Range {
    type Item = i32;
    type IntoIter = Range;

    fun into_iter(self) -> Self::IntoIter {
        self
    }
}

#[lang = "add"]
pub trait Add {
    type Output;
    fun add(self, rhs: Self) -> Self::Output;
}
#[lang = "sub"]
pub trait Sub { type Output; }
#[lang = "mul"]
pub trait Mul { type Output; }
#[lang = "div"]
pub trait Div { type Output; }
#[lang = "rem"]
pub trait Rem { type Output; }
#[lang = "neg"]
pub trait Neg { type Output; }
#[lang = "not"]
pub trait Not { type Output; }
#[lang = "bitand"]
pub trait BitAnd { type Output; }
#[lang = "bitor"]
pub trait BitOr { type Output; }
#[lang = "bitxor"]
pub trait BitXor { type Output; }
#[lang = "shl"]
pub trait Shl { type Output; }
#[lang = "shr"]
pub trait Shr { type Output; }
#[lang = "add_assign"]
pub trait AddAssign {}
#[lang = "sub_assign"]
pub trait SubAssign {}
#[lang = "mul_assign"]
pub trait MulAssign {}
#[lang = "div_assign"]
