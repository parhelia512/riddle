impl Add for f32 { type Output = f32; fun add(self, rhs: Self) -> Self::Output { self + rhs } }
impl Add for f64 { type Output = f64; fun add(self, rhs: Self) -> Self::Output { self + rhs } }
impl Add for f128 { type Output = f128; fun add(self, rhs: Self) -> Self::Output { self + rhs } }

