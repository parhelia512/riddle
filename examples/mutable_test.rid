mod A {
    trait Base {
        fun set(&mut self, value: i32);
        fun get(&self) -> i32;
    }

    impl Base for Cell {
        fun set(&mut self, value: i32) {
            self.value = value;
        }
    
        fun get(&self) -> i32 {
            self.value
        }
    }
}

use A::*;

struct Cell {
    value: i32,
}

fun main() -> i32 {
    let cell = Cell { value: 1 };

    cell.set(42);

    if cell.value == 42 {
        return 0;
    }

    return 1;
}
