struct Foo{
    x: i32,
    y: i32,
}

trait Bar{
    fun bar();
}

impl Bar for Foo{
    fun bar(){
        
    }

    fun help()->str{
        "HELP"
    }
}

fun main(){
    let t: Foo;
    {
        let x = Foo{x:1, y:1};
        t = x;
        print(x) // error
    }
    {
        let y = &Foo{x:1, y:1};
        t = y.clone();
        print(y) // yes
    }
}